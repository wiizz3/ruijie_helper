        self.load_all_config()
        self._delayed_hotspot_refresh()

    def generate_qr_code(self):
        """根据当前热点配置生成 WiFi 二维码。"""
        config = HotspotManager.load_config()
        ssid = config.get("ssid", "")
        password = config.get("password", "")
        if not ssid or not password:
            self.qr_label.setVisible(False)
            return
        try:
            import qrcode
            from io import BytesIO
            # 标准 WiFi 二维码格式
            wifi_string = f"WIFI:T:WPA;S:{ssid};P:{password};;"
            img = qrcode.make(wifi_string)
            buffer = BytesIO()
            img.save(buffer, format="PNG")
            pixmap = QPixmap()
            pixmap.loadFromData(buffer.getvalue(), "PNG")
            self.qr_label.setPixmap(pixmap.scaled(
                self.qr_label.size(), Qt.KeepAspectRatio, Qt.SmoothTransformation))
            self.qr_label.setVisible(True)
        except Exception as e:
            self.qr_label.setText(f"二维码生成失败\n{str(e)}")
            self.qr_label.setVisible(True)

    def toggle_password_visibility(self):
        """切换密码输入框的明文/密文显示。"""
        if self.password_edit.echoMode() == QLineEdit.Password:
            self.password_edit.setEchoMode(QLineEdit.Normal)
            self.toggle_pwd_btn.setText("🙈")
        else:
            self.password_edit.setEchoMode(QLineEdit.Password)
            self.toggle_pwd_btn.setText("👁️")

    def load_all_config(self):
        """加载所有配置项并填充界面控件。"""
        config = HotspotManager.load_config()
        self.ssid_edit.setText(config.get("ssid", ""))
        self.password_edit.setText(config.get("password", ""))
        band = config.get("band", "2.4GHz")
        idx = self.band_combo.findText(band)
        if idx >= 0:
            self.band_combo.setCurrentIndex(idx)
        target = SupplicantConfig.get_target_folder()
        self.target_edit.setText(target)
        self.update_move_buttons()

    def browse_target_folder(self):
        """浏览并设置移动目标文件夹。"""
        folder = QFileDialog.getExistingDirectory(self, "选择移动目标文件夹")
        if folder:
            self.target_edit.setText(folder)
            SupplicantConfig.set_target_folder(folder)

    def update_move_buttons(self):
        """根据是否有移动记录，启用/禁用“结束并移动”和“还原”按钮。"""
        record = SupplicantConfig.get_move_record()
        if record and record.get("action") == "kill_and_move":
            self.btn_kill_move.setEnabled(False)
            self.btn_restore.setEnabled(True)
        else:
            self.btn_kill_move.setEnabled(True)
            self.btn_restore.setEnabled(False)

    def save_hotspot_config(self):
        """保存热点配置（SSID、密码、频段）到文件。"""
        ssid = self.ssid_edit.text().strip()
        password = self.password_edit.text().strip()
        band = self.band_combo.currentText()
        if not ssid or not password:
            QMessageBox.warning(self, "错误", "热点名称和密码不能为空")
            return
        if len(password) < 8:
            QMessageBox.warning(self, "错误", "密码长度不能少于8位")
            return
        HotspotManager.save_config({"ssid": ssid, "password": password, "band": band})
        QMessageBox.information(self, "提示", "配置已保存")

    def _refresh_proc(self):
        """定时刷新 8021x.exe 进程状态和路径显示。"""
        running = SupplicantManager.is_running()
        if running:
            self.proc_status_label.setText("8021x.exe 运行中")
            self.proc_status_label.setStyleSheet("color: white; background-color: #dc3545;")
            path = SupplicantManager.get_exe_path()
            self.proc_path_label.setText(path if path else "无法获取路径")
        else:
            self.proc_status_label.setText("8021x.exe 未运行")
            self.proc_status_label.setStyleSheet("color: white; background-color: #28a745;")
            self.proc_path_label.setText("无")

    def _delayed_hotspot_refresh(self):
        """延迟200毫秒刷新热点状态（避免界面初始化阻塞）。"""
        QTimer.singleShot(200, self._refresh_hotspot_status)

    def _refresh_hotspot_status(self):
        """查询并更新热点状态与开关控件。"""
        try:
            status = HotspotManager.get_hotspot_status()
            self.hotspot_status_text.setText(status)
            self.hotspot_status_text.setStyleSheet("")
            self.hotspot_switch.blockSignals(True)  # 避免触发 toggle 信号
            self.hotspot_switch.setChecked(status == "已启动")
            self.hotspot_switch.blockSignals(False)
            if status == "已启动":
                self.generate_qr_code()
            else:
                self.qr_label.setVisible(False)
        except Exception:
            pass

    def toggle_hotspot(self):
        """用户点击开关按钮，启动/停止热点（在后台线程中执行）。"""
        self.hotspot_switch.setEnabled(False)   # 操作期间禁用开关
        self._anim_dots = 0
        self._anim_timer.start(400)
        self.hotspot_status_text.setText("正在切换.")   # 启动“正在切换...”动画
        self.hotspot_status_text.setStyleSheet("color: blue;")
        start = self.hotspot_switch.isChecked()
        threading.Thread(target=self._execute_toggle, args=(start,), daemon=True).start()

    def _animate_switching(self):
        """“正在切换...”文字动画（增加点数）。"""
        self._anim_dots = (self._anim_dots + 1) % 4
        dots = "." * self._anim_dots
        self.hotspot_status_text.setText(f"正在切换{dots}")

    def _execute_toggle(self, start):
        """后台线程实际执行热点开关操作，并通过信号通知 UI。"""
        if start:
            ok, msg = HotspotManager.start_hotspot()
        else:
            ok, msg = HotspotManager.stop_hotspot()
        self._signal.emit(ok, msg)

    def _on_operation_finished(self, ok, msg):
        """热点操作完成后的 UI 更新槽函数。"""
        self._anim_timer.stop()
        self.hotspot_switch.setEnabled(True)
        if ok:
            self._refresh_hotspot_status()
        else:
            self.hotspot_status_text.setText(f"❌ {msg}")
            self.hotspot_status_text.setStyleSheet("color: red;")
            QTimer.singleShot(3000, self._refresh_hotspot_status)   # 3秒后恢复状态显示

    def refresh(self):
        """刷新整个页面：进程状态、热点状态、移动按钮状态。"""
        self._refresh_proc()
        self._delayed_hotspot_refresh()
        self.update_move_buttons()

    def kill_and_move(self):
        """结束 8021x.exe 进程并移动文件到指定文件夹。"""
        if not SupplicantManager.is_running():
            QMessageBox.information(self, "提示", "8021x.exe 未运行")
            return
        target = self.target_edit.text().strip() or SupplicantConfig.get_target_folder()
        ok = SupplicantManager.kill_and_move(target)
        if ok:
            QMessageBox.information(self, "成功", f"进程已结束，文件已移动到 {target}")
            self.update_move_buttons()
        else:
            QMessageBox.warning(self, "失败", "操作失败，请检查进程权限或路径")
        self._refresh_proc()

    def restore(self):
        """将之前移动的文件还原到原始位置。"""
        ok = SupplicantManager.restore()
        if ok:
            QMessageBox.information(self, "成功", "文件已还原到原始路径")
            self.update_move_buttons()
        else:
            QMessageBox.warning(self, "失败", "还原失败，请确认文件是否存在或记录是否正确")
        self._refresh_proc()
